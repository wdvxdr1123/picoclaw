# ── LLM Provider ──────────────────────────
# Uncomment and set the API key for your provider
# OPENROUTER_API_KEY=sk-or-v1-xxx
# ZHIPU_API_KEY=xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx
# GEMINI_API_KEY=xxx
# CLAUDE_CODE_OAUTH=xxx
# ── Chat Channel ──────────────────────────
# TELEGRAM_BOT_TOKEN=123456:ABC...
# DISCORD_BOT_TOKEN=xxx

# ── Web Search (optional) ────────────────
# BRAVE_SEARCH_API_KEY=BSA...
# PICOCLAW_TOOLS_WEB_SEARCH_PROVIDER=openai
# PICOCLAW_TOOLS_WEB_OPENAI_SEARCH_ENABLED=true
# PICOCLAW_TOOLS_WEB_OPENAI_SEARCH_API_KEY=xxxx
# PICOCLAW_TOOLS_WEB_OPENAI_SEARCH_BASE_URL=http://jeniya.cn/v1/chat/completions
# PICOCLAW_TOOLS_WEB_OPENAI_SEARCH_MODEL=grok-4-fast

# ── Timezone ──────────────────────────────
TZ=Asia/Shanghai
